// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

// =============================================================================
// AUDIT LOG - Tracks all Create, Update, Delete operations
// =============================================================================

model AuditLog {
  id          String   @id @default(cuid())
  user_id     String
  user_name   String
  action      String   // create | update | delete
  entity_type String   // e.g., "auditable_entity", "engagement"
  entity_id   String
  changes     Json?    // For updates: { field: { old, new } }
  timestamp   DateTime @default(now())

  @@index([entity_type, entity_id])
  @@index([user_id])
  @@index([timestamp])
  @@map("audit_log")
}

// =============================================================================
// SETTINGS MODULE
// =============================================================================

model SystemSetting {
  key        String   @id
  value      Json
  updated_at DateTime @updatedAt
  updated_by String?

  @@map("system_setting")
}

model Contact {
  id         String    @id @default(cuid())
  name       String
  position   String?
  email      String?
  phone      String?
  unit_id    String?
  status     String    @default("active") // active | inactive
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  updated_by String?

  unit          OrgUnit?  @relation("ContactUnit", fields: [unit_id], references: [id])
  led_units     OrgUnit[] @relation("OrgUnitLeader")
  contact_units OrgUnit[] @relation("OrgUnitContactPoint")
  audit_sponsored_entities AuditableEntityAuditSponsor[] @relation("EntityAuditSponsor")
  auditee_rep_entities     AuditableEntityAuditeeRep[]   @relation("EntityAuditeeRep")
  entity_contact_points    AuditableEntityContactPoint[] @relation("EntityContactPoint")
  // PlannedAudit relations
  planned_audit_contact_points PlannedAuditContactPoint[] @relation("PAContactPoint")
  planned_audit_auditee_reps   PlannedAuditAuditeeRep[]   @relation("PAAuditeeRep")
  // Engagement relations
  engagement_contact_points    EngagementContactPoint[]    @relation("EngContactPoint")
  engagement_auditee_reps      EngagementAuditeeRep[]      @relation("EngAuditeeRep")
  finding_risk_owners          DraftFindingRiskOwner[]     @relation("FindingRiskOwner")

  @@index([status])
  @@index([unit_id])
  @@map("contact")
}

model OrgUnit {
  id               String    @id @default(cuid())
  name             String
  code             String?   @unique
  parent_id        String?
  leader_id        String?
  contact_point_id String?
  description      String?   @db.Text
  status           String    @default("active") // active | inactive
  established      DateTime?
  discontinued     DateTime?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt
  updated_by       String?

  parent        OrgUnit?  @relation("OrgUnitHierarchy", fields: [parent_id], references: [id])
  children      OrgUnit[] @relation("OrgUnitHierarchy")
  leader        Contact?  @relation("OrgUnitLeader", fields: [leader_id], references: [id])
  contact_point Contact?  @relation("OrgUnitContactPoint", fields: [contact_point_id], references: [id])
  contacts      Contact[] @relation("ContactUnit")
  owned_entities        AuditableEntityOwner[]       @relation("EntityOwner")
  participated_entities AuditableEntityParticipant[] @relation("EntityParticipant")
  // PlannedAudit relations
  planned_audit_owners       PlannedAuditOwner[]       @relation("PAOwner")
  planned_audit_participants PlannedAuditParticipant[] @relation("PAParticipant")
  // Engagement relations
  engagement_owners          EngagementOwner[]          @relation("EngOwner")
  engagement_participants    EngagementParticipant[]    @relation("EngParticipant")
  finding_unit_owners        DraftFindingUnitOwner[]    @relation("FindingUnitOwner")

  @@index([parent_id])
  @@index([status])
  @@map("org_unit")
}

// =============================================================================
// TEAMS MODULE — Users, Teams, Roles, Permissions
// =============================================================================

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password_hash String?   // null for SSO-only users
  phone         String?
  title         String?   // job title (free text, independent of system role)
  role          String    @default("auditor") // cae | admin | audit_director | audit_manager | senior_auditor | auditor
  status        String    @default("active") // active | locked | inactive
  provider      String    @default("credentials") // credentials | entra_id
  supervisor_id String?   // self-ref FK — default reviewer
  description   String?   @db.Text // personal note / self-description
  avatar_url    String?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  supervisor    User?     @relation("UserSupervisor", fields: [supervisor_id], references: [id])
  subordinates  User[]    @relation("UserSupervisor")
  user_roles    UserRole[]
  expertises    UserExpertise[]
  owned_teams   Team[]    @relation("TeamOwner")
  team_memberships TeamMember[]
  engagement_memberships EngagementMember[] @relation("EngagementMembers")
  wp_assignments         WpAssignment[]    @relation("WpAssignments")
  wp_signoffs            WpSignoff[]       @relation("WpSignoffs")
  wp_comments            WpComment[]       @relation("WpCommentAuthor")
  wp_thread_creators     WpCommentThread[] @relation("WpThreadCreator")
  created_templates      Template[]        @relation("TemplateCreator")
  published_versions     EntityVersion[]   @relation("VersionPublisher")

  @@index([status])
  @@index([role])
  @@index([supervisor_id])
  @@map("user")
}

model Team {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?   @db.Text
  owner_id    String
  status      String    @default("active") // active | inactive
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  owner   User         @relation("TeamOwner", fields: [owner_id], references: [id])
  members TeamMember[]

  @@index([owner_id])
  @@index([status])
  @@map("team")
}

model TeamMember {
  team_id   String
  user_id   String
  role      String    @default("member") // owner | member
  joined_at DateTime  @default(now())

  team Team @relation(fields: [team_id], references: [id], onDelete: Cascade)
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@id([team_id, user_id])
  @@index([user_id])
  @@map("team_member")
}

model Role {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  is_system   Boolean   @default(false)
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  user_roles  UserRole[]
  permissions Permission[]

  @@map("role")
}

model UserRole {
  user_id String
  role_id String

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  role Role @relation(fields: [role_id], references: [id], onDelete: Cascade)

  @@id([user_id, role_id])
  @@index([role_id])
  @@map("user_role")
}

model Permission {
  id      String @id @default(cuid())
  role_id String
  module  String // e.g., "engagement", "finding", "teams"
  action  String // e.g., "create", "read", "update", "delete", "manage"

  role Role @relation(fields: [role_id], references: [id], onDelete: Cascade)

  @@unique([role_id, module, action])
  @@index([role_id])
  @@map("permission")
}

model Expertise {
  id          String   @id @default(cuid())
  label       String
  code        String?  @unique
  description String?
  sort_order  Int      @default(0)
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  users UserExpertise[]

  @@index([is_active])
  @@map("expertise")
}

model UserExpertise {
  user_id      String
  expertise_id String

  user      User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  expertise Expertise @relation(fields: [expertise_id], references: [id], onDelete: Cascade)

  @@id([user_id, expertise_id])
  @@index([expertise_id])
  @@map("user_expertise")
}

// =============================================================================
// UNIVERSE MODULE — Reference Data
// =============================================================================

model EntityType {
  id          String   @id @default(cuid())
  name        String
  code        String?  @unique
  description String?
  is_active   Boolean  @default(true)
  sort_order  Int      @default(0)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  entities AuditableEntity[]

  @@index([is_active])
  @@map("entity_type")
}

model AuditArea {
  id          String   @id @default(cuid())
  name        String
  code        String?  @unique
  description String?
  is_active   Boolean  @default(true)
  sort_order  Int      @default(0)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  entity_areas AuditableEntityArea[]

  @@index([is_active])
  @@map("audit_area")
}

// =============================================================================
// UNIVERSE MODULE — Auditable Entities
// =============================================================================

model AuditableEntity {
  id                 String    @id @default(cuid())
  name               String
  code               String?   @unique
  description        String?   @db.Text
  entity_type_id     String?   // FK to EntityType (nullable for migration)
  status             String    @default("active") // active | inactive | archived
  audit_cycle        String?   // Annual, Biennial, Triennial, Ad-hoc, Continuous
  // Denormalized risk (populated from latest RiskAssessment)
  risk_score              Int?      // residual (effective) score
  risk_level              String?   // derived from risk_score
  inherent_risk_score     Int?      // inherent_impact × inherent_likelihood
  inherent_risk_level     String?   // derived from inherent_risk_score
  // Timestamps
  last_audited_at    DateTime?
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt
  updated_by         String?

  entity_type           EntityType? @relation(fields: [entity_type_id], references: [id])
  areas                 AuditableEntityArea[]
  owner_units           AuditableEntityOwner[]
  participating_units   AuditableEntityParticipant[]
  audit_sponsors        AuditableEntityAuditSponsor[]
  auditee_reps          AuditableEntityAuditeeRep[]
  contact_points        AuditableEntityContactPoint[]
  risk_assessments      RiskAssessment[]
  entity_risks          EntityRisk[]
  planned_audits        PlannedAudit[]
  engagements           Engagement[]

  @@index([entity_type_id])
  @@index([status])
  @@index([risk_level])
  @@map("auditable_entity")
}

model AuditableEntityArea {
  entity_id String
  area_id   String

  entity AuditableEntity @relation(fields: [entity_id], references: [id], onDelete: Cascade)
  area   AuditArea       @relation(fields: [area_id], references: [id])

  @@id([entity_id, area_id])
  @@map("auditable_entity_area")
}

model AuditableEntityOwner {
  entity_id String
  unit_id   String

  entity AuditableEntity @relation(fields: [entity_id], references: [id], onDelete: Cascade)
  unit   OrgUnit         @relation("EntityOwner", fields: [unit_id], references: [id])

  @@id([entity_id, unit_id])
  @@map("auditable_entity_owner")
}

model AuditableEntityParticipant {
  entity_id String
  unit_id   String

  entity AuditableEntity @relation(fields: [entity_id], references: [id], onDelete: Cascade)
  unit   OrgUnit         @relation("EntityParticipant", fields: [unit_id], references: [id])

  @@id([entity_id, unit_id])
  @@map("auditable_entity_participant")
}

model AuditableEntityContactPoint {
  entity_id  String
  contact_id String

  entity  AuditableEntity @relation(fields: [entity_id], references: [id], onDelete: Cascade)
  contact Contact         @relation("EntityContactPoint", fields: [contact_id], references: [id])

  @@id([entity_id, contact_id])
  @@map("auditable_entity_contact_point")
}

model AuditableEntityAuditSponsor {
  entity_id  String
  contact_id String

  entity  AuditableEntity @relation(fields: [entity_id], references: [id], onDelete: Cascade)
  contact Contact         @relation("EntityAuditSponsor", fields: [contact_id], references: [id])

  @@id([entity_id, contact_id])
  @@map("auditable_entity_audit_sponsor")
}

model AuditableEntityAuditeeRep {
  entity_id  String
  contact_id String

  entity  AuditableEntity @relation(fields: [entity_id], references: [id], onDelete: Cascade)
  contact Contact         @relation("EntityAuditeeRep", fields: [contact_id], references: [id])

  @@id([entity_id, contact_id])
  @@map("auditable_entity_auditee_rep")
}

model RiskAssessment {
  id                    String    @id @default(cuid())
  entity_id             String

  // Section 1: Inherent Risk
  inherent_score        Int       // required — auto I×L or user-overridden
  inherent_level        String    // Low, Medium, High, Critical — derived from inherent_score
  inherent_impact       Int?      // 1-5 — optional detail
  inherent_likelihood   Int?      // 1-5 — optional detail
  impact_rationale      String?   @db.Text  // optional rationale for impact score
  likelihood_rationale  String?   @db.Text  // optional rationale for likelihood score

  // Section 2: Control Environment
  control_effectiveness String?   // Strong | Medium | Weak
  control_rationale     String?   @db.Text  // optional rationale for control assessment

  // Section 3: Assessment Info
  risk_factors          Json?     // { impact: string[], likelihood: string[], control: string[] }
  assessment_source_id  String?   // FK to AssessmentSource
  note                  String?   @db.Text  // detailed assessment note
  management_request    Boolean   @default(false) // yêu cầu của ban lãnh đạo

  // Section 4: Residual Risk
  residual_score        Int?      // auto-calculated or user-overridden
  residual_level        String?   // derived from residual_score
  conclusion            String?   @db.Text  // residual risk conclusion

  // Section 5: Metadata (placeholders — will link to User when Teams module is implemented)
  evaluated_by          String?
  approved_by           String?
  evaluation_date       DateTime  @default(now())

  entity            AuditableEntity  @relation(fields: [entity_id], references: [id], onDelete: Cascade)
  assessment_source AssessmentSource? @relation(fields: [assessment_source_id], references: [id])

  @@index([entity_id])
  @@index([evaluation_date])
  @@index([assessment_source_id])
  @@map("risk_assessment")
}

model AssessmentSource {
  id          String   @id @default(cuid())
  name        String
  code        String?  @unique
  description String?
  is_active   Boolean  @default(true)
  sort_order  Int      @default(0)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  risk_assessments RiskAssessment[]

  @@index([is_active])
  @@map("assessment_source")
}

// =============================================================================
// RISK ASSESSMENT FACTORS - Dynamic factors for risk assessment (managed in Settings)
// =============================================================================

model RiskAssessmentFactor {
  id          String   @id @default(cuid())
  name        String
  code        String?  @unique
  description String?
  relates_to  String   @default("impact") // impact | likelihood | control
  is_positive Boolean  @default(false)    // false = negative factor (increases risk), true = positive (mitigates risk)
  is_active   Boolean  @default(true)
  sort_order  Int      @default(0)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([is_active])
  @@index([relates_to])
  @@map("risk_assessment_factor")
}

// =============================================================================
// RISK CATALOG LIBRARY — Org-level risk, control & procedure library
// Structured: Domain → Category → Items (risks, controls, procedures)
// Pre-populated from frameworks (COBIT 2019, COSO ERM) + user-added
// =============================================================================

model RiskCatalogDomain {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  framework   String?  // "COBIT 2019" | "COSO ERM" | "Custom" | null
  description String?  @db.Text
  sort_order  Int      @default(0)
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  categories RiskCatalogCategory[]

  @@index([framework])
  @@index([is_active])
  @@map("risk_catalog_domain")
}

model RiskCatalogCategory {
  id          String   @id @default(cuid())
  domain_id   String
  name        String
  code        String   @unique
  description String?  @db.Text
  sort_order  Int      @default(0)
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  domain RiskCatalogDomain @relation(fields: [domain_id], references: [id], onDelete: Cascade)
  risks  RiskCatalogItem[]

  @@index([domain_id])
  @@index([is_active])
  @@map("risk_catalog_category")
}

model RiskCatalogItem {
  id            String   @id @default(cuid())
  category_id   String
  name          String
  code          String?  @unique
  description   String?  @db.Text
  risk_type     String?  // operational | financial | compliance | strategic | it | governance | reputational
  risk_rating   String?  // low | medium | high | critical
  likelihood    String?  // rare | unlikely | possible | likely | almost_certain
  impact        String?  // insignificant | minor | moderate | major | catastrophic
  framework_ref String?  // e.g., "COBIT EDM01.01", "COSO P-03"
  source        String   @default("system") // system | custom
  is_active     Boolean  @default(true)
  sort_order    Int      @default(0)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  category     RiskCatalogCategory   @relation(fields: [category_id], references: [id], onDelete: Cascade)
  control_refs RiskControlCatalogRef[]
  entity_risks EntityRisk[]          // universe entity risks referencing this catalog item
  engagement_risks EngagementRisk[]  // engagement RCM risks referencing this catalog item

  @@index([category_id])
  @@index([source])
  @@index([risk_type])
  @@index([is_active])
  @@map("risk_catalog_item")
}

model ControlCatalogItem {
  id             String   @id @default(cuid())
  name           String
  code           String?  @unique
  description    String?  @db.Text
  control_type   String?  // preventive | detective | corrective
  control_nature String?  // manual | automated | it_dependent
  frequency      String?  // continuous | daily | weekly | monthly | quarterly | annually | event_driven
  framework_ref  String?  // e.g., "COBIT APO01-C01"
  source         String   @default("system") // system | custom
  is_active      Boolean  @default(true)
  sort_order     Int      @default(0)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  risk_refs      RiskControlCatalogRef[]
  procedure_refs ControlProcedureCatalogRef[]
  engagement_controls EngagementControl[] // engagement controls referencing this catalog item

  @@index([source])
  @@index([control_type])
  @@index([is_active])
  @@map("control_catalog_item")
}

model ProcedureCatalogItem {
  id                 String   @id @default(cuid())
  name               String
  code               String?  @unique
  description        String?  @db.Text
  procedure_type     String?  // inquiry | observation | inspection | re_performance | analytical | walkthrough | other
  procedure_category String?  // toc | substantive
  framework_ref      String?  // e.g., "COBIT APO01-P01"
  source             String   @default("system") // system | custom
  is_active          Boolean  @default(true)
  sort_order         Int      @default(0)
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  control_refs       ControlProcedureCatalogRef[]
  engagement_procedures EngagementProcedure[] // engagement procedures referencing this catalog item

  @@index([source])
  @@index([procedure_type])
  @@index([is_active])
  @@map("procedure_catalog_item")
}

// M:N junction: RiskCatalogItem ↔ ControlCatalogItem
model RiskControlCatalogRef {
  risk_catalog_id    String
  control_catalog_id String

  risk    RiskCatalogItem    @relation(fields: [risk_catalog_id], references: [id], onDelete: Cascade)
  control ControlCatalogItem @relation(fields: [control_catalog_id], references: [id], onDelete: Cascade)

  @@id([risk_catalog_id, control_catalog_id])
  @@map("risk_control_catalog_ref")
}

// M:N junction: ControlCatalogItem ↔ ProcedureCatalogItem
model ControlProcedureCatalogRef {
  control_catalog_id   String
  procedure_catalog_id String

  control   ControlCatalogItem   @relation(fields: [control_catalog_id], references: [id], onDelete: Cascade)
  procedure ProcedureCatalogItem @relation(fields: [procedure_catalog_id], references: [id], onDelete: Cascade)

  @@id([control_catalog_id, procedure_catalog_id])
  @@map("control_procedure_catalog_ref")
}

// =============================================================================
// ENTITY RISK — Risks assigned to a specific auditable entity
// Copied from catalogue or created ad-hoc; detached but referenceable
// =============================================================================

model EntityRisk {
  id                  String   @id @default(cuid())
  entity_id           String
  catalogue_item_id   String?  // nullable FK — null means ad-hoc / custom risk
  name                String
  code                String?
  description         String?  @db.Text
  risk_type           String   // copied from catalogue or set manually
  risk_domain         String?  // copied from catalogue or set manually
  is_primary          Boolean  @default(false) // marks as primary risk for the entity
  sort_order          Int      @default(0)
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  entity         AuditableEntity  @relation(fields: [entity_id], references: [id], onDelete: Cascade)
  catalogue_item RiskCatalogItem? @relation(fields: [catalogue_item_id], references: [id], onDelete: SetNull)

  @@unique([entity_id, catalogue_item_id]) // prevent duplicate catalogue references per entity
  @@index([entity_id])
  @@index([catalogue_item_id])
  @@index([is_primary])
  @@map("entity_risk")
}

// =============================================================================
// PLAN MODULE — Audit Planning
// =============================================================================

model AuditPlan {
  id           String    @id @default(cuid())
  title        String
  description  String?   @db.Text
  period_type  String    // annual | quarterly | monthly | custom
  period_start DateTime  @db.Date
  period_end   DateTime  @db.Date
  status       String    @default("draft") // draft | approved | in_progress | closed
  created_by   String?   // placeholder — will link to User
  approved_by  String?   // placeholder — who approved
  approved_at  DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  updated_by   String?

  planned_audits PlannedAudit[]

  @@index([status])
  @@index([period_type])
  @@index([period_start])
  @@map("audit_plan")
}

model PlannedAudit {
  id              String    @id @default(cuid())
  plan_id         String
  entity_id       String
  title           String?   // override title; defaults to entity name if empty
  objective       String?   @db.Text
  scope           String?   @db.Text
  scheduled_start DateTime  @db.Date
  scheduled_end   DateTime  @db.Date
  status          String    @default("planned") // planned | in_progress | completed | deferred | cancelled
  priority        String?   // high | medium | low
  estimated_days  Int?
  notes           String?   @db.Text
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  plan       AuditPlan       @relation(fields: [plan_id], references: [id], onDelete: Cascade)
  entity     AuditableEntity @relation(fields: [entity_id], references: [id])
  engagement Engagement?     // reverse 1:1
  owner_units         PlannedAuditOwner[]
  participating_units PlannedAuditParticipant[]
  contact_points      PlannedAuditContactPoint[]
  auditee_reps        PlannedAuditAuditeeRep[]

  @@unique([plan_id, entity_id]) // entity can only appear once per plan
  @@index([plan_id])
  @@index([entity_id])
  @@index([status])
  @@map("planned_audit")
}

model PlannedAuditOwner {
  planned_audit_id String
  unit_id          String

  planned_audit PlannedAudit @relation(fields: [planned_audit_id], references: [id], onDelete: Cascade)
  unit          OrgUnit      @relation("PAOwner", fields: [unit_id], references: [id])

  @@id([planned_audit_id, unit_id])
  @@map("planned_audit_owner")
}

model PlannedAuditParticipant {
  planned_audit_id String
  unit_id          String

  planned_audit PlannedAudit @relation(fields: [planned_audit_id], references: [id], onDelete: Cascade)
  unit          OrgUnit      @relation("PAParticipant", fields: [unit_id], references: [id])

  @@id([planned_audit_id, unit_id])
  @@map("planned_audit_participant")
}

model PlannedAuditContactPoint {
  planned_audit_id String
  contact_id       String

  planned_audit PlannedAudit @relation(fields: [planned_audit_id], references: [id], onDelete: Cascade)
  contact       Contact      @relation("PAContactPoint", fields: [contact_id], references: [id])

  @@id([planned_audit_id, contact_id])
  @@map("planned_audit_contact_point")
}

model PlannedAuditAuditeeRep {
  planned_audit_id String
  contact_id       String

  planned_audit PlannedAudit @relation(fields: [planned_audit_id], references: [id], onDelete: Cascade)
  contact       Contact      @relation("PAAuditeeRep", fields: [contact_id], references: [id])

  @@id([planned_audit_id, contact_id])
  @@map("planned_audit_auditee_rep")
}

// =============================================================================
// ENGAGEMENT MODULE — Audit Execution
// =============================================================================

model Engagement {
  id               String    @id @default(cuid())
  title            String
  entity_id        String
  planned_audit_id String?   @unique // nullable — only set when created from plan
  status           String    @default("planning") // planning | fieldwork | review | reporting | closed
  objective        String?   @db.Text
  scope            String?   @db.Text
  understanding    String?   @db.Text  // rich-text HTML from Tiptap
  start_date       DateTime  @db.Date
  end_date         DateTime  @db.Date
  estimated_days   Int?
  priority         String?   // high | medium | low
  notes            String?   @db.Text
  // Work-program overall approval
  wp_approval_status  String   @default("not_started")  // not_started | in_progress | waiting_review | needs_modification | reviewed | waiting_approval | approved
  wp_approved_by      String?
  wp_approved_at      DateTime?
  wp_approved_version Int?
  created_by       String?   // placeholder — will link to User
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt
  updated_by       String?

  entity        AuditableEntity @relation(fields: [entity_id], references: [id])
  planned_audit PlannedAudit?   @relation(fields: [planned_audit_id], references: [id])
  sections           EngagementSection[]
  objectives         EngagementObjective[] // includes standalone objectives (no section)
  procedures         EngagementProcedure[] // procedures directly under engagement (no section)
  findings           DraftFinding[]
  audit_objectives   AuditObjective[]
  rcm_objectives     EngagementRcmObjective[]
  risks              EngagementRisk[]
  controls           EngagementControl[]
  members             EngagementMember[]
  wp_assignments      WpAssignment[]
  wp_signoffs         WpSignoff[]
  owner_units         EngagementOwner[]
  participating_units EngagementParticipant[]
  contact_points      EngagementContactPoint[]
  auditee_reps        EngagementAuditeeRep[]
  planning_workpapers PlanningWorkpaper[]

  @@index([status])
  @@index([entity_id])
  @@index([planned_audit_id])
  @@map("engagement")
}

model EngagementOwner {
  engagement_id String
  unit_id       String

  engagement Engagement @relation(fields: [engagement_id], references: [id], onDelete: Cascade)
  unit       OrgUnit    @relation("EngOwner", fields: [unit_id], references: [id])

  @@id([engagement_id, unit_id])
  @@map("engagement_owner")
}

model EngagementParticipant {
  engagement_id String
  unit_id       String

  engagement Engagement @relation(fields: [engagement_id], references: [id], onDelete: Cascade)
  unit       OrgUnit    @relation("EngParticipant", fields: [unit_id], references: [id])

  @@id([engagement_id, unit_id])
  @@map("engagement_participant")
}

model EngagementContactPoint {
  engagement_id String
  contact_id    String

  engagement Engagement @relation(fields: [engagement_id], references: [id], onDelete: Cascade)
  contact    Contact    @relation("EngContactPoint", fields: [contact_id], references: [id])

  @@id([engagement_id, contact_id])
  @@map("engagement_contact_point")
}

model EngagementAuditeeRep {
  engagement_id String
  contact_id    String

  engagement Engagement @relation(fields: [engagement_id], references: [id], onDelete: Cascade)
  contact    Contact    @relation("EngAuditeeRep", fields: [contact_id], references: [id])

  @@id([engagement_id, contact_id])
  @@map("engagement_auditee_rep")
}

model EngagementMember {
  engagement_id String
  user_id       String
  role          String    @default("member") // lead | member | reviewer | observer
  joined_at     DateTime  @default(now())

  engagement Engagement @relation(fields: [engagement_id], references: [id], onDelete: Cascade)
  user       User       @relation("EngagementMembers", fields: [user_id], references: [id], onDelete: Cascade)

  @@id([engagement_id, user_id])
  @@index([user_id])
  @@map("engagement_member")
}

// Polymorphic work-program assignment: assigns a user to a section, objective, or procedure
model WpAssignment {
  id            String   @id @default(cuid())
  engagement_id String
  user_id       String
  entity_type   String   // 'section' | 'objective' | 'procedure'
  entity_id     String
  created_at    DateTime @default(now())

  engagement Engagement @relation(fields: [engagement_id], references: [id], onDelete: Cascade)
  user       User       @relation("WpAssignments", fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, entity_type, entity_id])
  @@index([engagement_id])
  @@index([entity_type, entity_id])
  @@map("wp_assignment")
}

// Immutable sign-off records: formal audit trail of who prepared/reviewed/approved
model WpSignoff {
  id              String    @id @default(cuid())
  engagement_id   String
  entity_type     String    // 'procedure' | 'planning_workpaper' | 'work_program'
  entity_id       String
  signoff_type    String    // 'prepare' | 'review' | 'approve'
  signoff_order   Int       @default(1) // which round (1,2,3...) — matches derived order from workflow
  user_id         String
  signed_at       DateTime  @default(now())
  version         Int?      // entity version at time of sign-off (links to EntityVersion)
  transition_id   String?   // which ApprovalTransition triggered this (null for manual signoff)
  invalidated_at  DateTime?
  invalidated_by  String?
  invalidation_reason String? // 'content_changed' | 'user_unsign' | 'cascade_unsign'
  comment         String?   @db.Text

  engagement Engagement @relation(fields: [engagement_id], references: [id], onDelete: Cascade)
  user       User       @relation("WpSignoffs", fields: [user_id], references: [id])

  @@index([engagement_id])
  @@index([entity_type, entity_id])
  @@index([signoff_type])
  @@map("wp_signoff")
}

// Planning-level audit objectives (distinct from execution EngagementObjective)
model AuditObjective {
  id            String    @id @default(cuid())
  engagement_id String
  title         String
  description   String?   @db.Text
  sort_order    Int       @default(0)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  engagement      Engagement              @relation(fields: [engagement_id], references: [id], onDelete: Cascade)
  rcm_objectives EngagementRcmObjective[]

  @@index([engagement_id])
  @@index([sort_order])
  @@map("audit_objective")
}

// RCM Objective — detached copy of AuditObjective for independent editing in RCM
model EngagementRcmObjective {
  id                 String    @id @default(cuid())
  engagement_id      String
  audit_objective_id String?   // reference back to source audit objective (nullable)
  title              String
  description        String?   @db.Text
  sort_order         Int       @default(0)
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt

  engagement      Engagement      @relation(fields: [engagement_id], references: [id], onDelete: Cascade)
  audit_objective AuditObjective? @relation(fields: [audit_objective_id], references: [id], onDelete: SetNull)
  risks           EngagementRisk[]
  procedure_refs  ProcedureObjectiveRef[]

  @@index([engagement_id])
  @@index([audit_objective_id])
  @@index([sort_order])
  @@map("engagement_rcm_objective")
}

// RACM — risk rows mapped to RCM objectives
model EngagementRisk {
  id                 String    @id @default(cuid())
  engagement_id      String
  rcm_objective_id   String?
  catalog_risk_id    String?   // nullable FK — reference to catalog library item (traceability)
  risk_description   String    @db.Text
  risk_rating        String?   // low | medium | high | critical
  risk_category      String?   // operational | financial | compliance | strategic | it
  likelihood         String?   // rare | unlikely | possible | likely | almost_certain
  impact             String?   // insignificant | minor | moderate | major | catastrophic
  workpaper_content  Json?     // TipTap JSON for rich text workpaper
  sort_order         Int       @default(0)
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt

  engagement      Engagement              @relation(fields: [engagement_id], references: [id], onDelete: Cascade)
  rcm_objective   EngagementRcmObjective?  @relation(fields: [rcm_objective_id], references: [id], onDelete: SetNull)
  catalog_risk    RiskCatalogItem?         @relation(fields: [catalog_risk_id], references: [id], onDelete: SetNull)
  control_refs    RiskControlRef[]
  procedure_refs  ProcedureRiskRef[]

  @@index([engagement_id])
  @@index([rcm_objective_id])
  @@index([catalog_risk_id])
  @@index([sort_order])
  @@map("engagement_risk")
}

// Control — engagement-level entity, linked to risks via M:N junction table
model EngagementControl {
  id                  String    @id @default(cuid())
  engagement_id       String
  catalog_control_id  String?   // nullable FK — reference to catalog library item (traceability)
  description         String    @db.Text
  effectiveness       String?   // strong | adequate | weak | none
  control_type        String?   // preventive | detective | corrective
  control_nature      String?   // manual | automated | it_dependent
  frequency           String?   // continuous | daily | weekly | monthly | quarterly | annually | event_driven
  workpaper_content   Json?     // TipTap JSON for rich text workpaper
  sort_order          Int       @default(0)
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  engagement      Engagement          @relation(fields: [engagement_id], references: [id], onDelete: Cascade)
  catalog_control ControlCatalogItem? @relation(fields: [catalog_control_id], references: [id], onDelete: SetNull)
  risk_refs       RiskControlRef[]
  procedure_refs  ProcedureControlRef[]

  @@index([engagement_id])
  @@index([catalog_control_id])
  @@index([sort_order])
  @@map("engagement_control")
}

// M:N junction: EngagementRisk ↔ EngagementControl
model RiskControlRef {
  risk_id    String
  control_id String

  risk    EngagementRisk    @relation(fields: [risk_id], references: [id], onDelete: Cascade)
  control EngagementControl @relation(fields: [control_id], references: [id], onDelete: Cascade)

  @@id([risk_id, control_id])
  @@map("risk_control_ref")
}

model EngagementSection {
  id            String    @id @default(cuid())
  engagement_id String
  title         String
  description   String?   @db.Text
  status        String    @default("not_started") // not_started | in_progress | waiting_review | reviewed
  phase          String    @default("planning")   // planning | execution
  planning_ref_id String?                          // FK → self (execution item → planning item)
  source         String    @default("planned")     // planned | fieldwork
  sort_order    Int       @default(0)
  review_notes  String?   @db.Text
  reviewed_by   String?
  reviewed_at   DateTime?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  engagement      Engagement            @relation(fields: [engagement_id], references: [id], onDelete: Cascade)
  planning_ref    EngagementSection?    @relation("SectionPlanningRef", fields: [planning_ref_id], references: [id], onDelete: SetNull)
  execution_refs  EngagementSection[]   @relation("SectionPlanningRef")
  objectives EngagementObjective[]
  procedures EngagementProcedure[] // procedures directly under section (no objective)

  @@index([engagement_id])
  @@index([phase])
  @@index([planning_ref_id])
  @@index([sort_order])
  @@map("engagement_section")
}

model EngagementObjective {
  id            String    @id @default(cuid())
  engagement_id String
  section_id    String?   // nullable — if null, objective is standalone (top-level)
  title         String
  description   String?   @db.Text
  status        String    @default("not_started") // not_started | in_progress | waiting_review | reviewed
  phase          String    @default("planning")   // planning | execution
  planning_ref_id String?                          // FK → self (execution item → planning item)
  source         String    @default("planned")     // planned | fieldwork
  sort_order    Int       @default(0)
  review_notes  String?   @db.Text
  reviewed_by   String?
  reviewed_at   DateTime?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  engagement      Engagement            @relation(fields: [engagement_id], references: [id], onDelete: Cascade)
  section         EngagementSection?    @relation(fields: [section_id], references: [id], onDelete: Cascade)
  planning_ref    EngagementObjective?  @relation("ObjectivePlanningRef", fields: [planning_ref_id], references: [id], onDelete: SetNull)
  execution_refs  EngagementObjective[] @relation("ObjectivePlanningRef")
  procedures EngagementProcedure[]

  @@index([engagement_id])
  @@index([section_id])
  @@index([phase])
  @@index([planning_ref_id])
  @@index([sort_order])
  @@map("engagement_objective")
}

model EngagementProcedure {
  id                   String    @id @default(cuid())
  engagement_id        String
  section_id           String?   // nullable — if null, procedure is directly under engagement
  objective_id         String?   // nullable — if null, procedure is under section or engagement
  catalog_procedure_id String?   // nullable FK — reference to catalog library item (traceability)
  title                String
  description    String?   @db.Text
  procedures     String?   @db.Text  // detailed testing steps / methodology
  procedure_type     String?   // inquiry | observation | inspection | re_performance | analytical | walkthrough | other
  procedure_category String?   // toc | substantive
  status         String    @default("not_started") // DEPRECATED — use approval_status instead
  approval_status   String    @default("not_started")  // not_started | in_progress | waiting_review | needs_modification | approved
  current_version   Int       @default(0)             // last published version (0 = never published)
  approved_by       String?
  approved_at       DateTime?
  approved_version  Int?                               // which version was approved
  phase          String    @default("planning")   // planning | execution
  planning_ref_id String?                          // FK → self (execution item → planning item)
  source         String    @default("planned")     // planned | fieldwork
  observations   String?   @db.Text  // what was found during testing
  conclusion     String?   @db.Text  // auditor's conclusion
  effectiveness  String?   // effective | ineffective
  sample_size    Int?      // number of items tested
  exceptions     Int?      // number of exceptions found
  sort_order     Int       @default(0)
  priority       String?   // high | medium | low
  content        Json?     @db.Json   // unified Tiptap document JSON (replaces separate rich text fields)
  review_notes   String?   @db.Text
  performed_by   String?   // placeholder — will link to User
  reviewed_by    String?   // placeholder — will link to User
  performed_at   DateTime?
  reviewed_at    DateTime?
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  engagement         Engagement            @relation(fields: [engagement_id], references: [id], onDelete: Cascade)
  section            EngagementSection?    @relation(fields: [section_id], references: [id], onDelete: Cascade)
  objective          EngagementObjective?  @relation(fields: [objective_id], references: [id], onDelete: Cascade)
  catalog_procedure  ProcedureCatalogItem? @relation(fields: [catalog_procedure_id], references: [id], onDelete: SetNull)
  planning_ref       EngagementProcedure?  @relation("ProcedurePlanningRef", fields: [planning_ref_id], references: [id], onDelete: SetNull)
  execution_refs     EngagementProcedure[] @relation("ProcedurePlanningRef")
  findings           DraftFindingProcedure[]
  ref_controls       ProcedureControlRef[]
  ref_risks          ProcedureRiskRef[]
  ref_objectives     ProcedureObjectiveRef[]

  @@index([engagement_id])
  @@index([section_id])
  @@index([objective_id])
  @@index([catalog_procedure_id])
  @@index([phase])
  @@index([planning_ref_id])
  @@index([sort_order])
  @@index([status])
  @@map("engagement_procedure")
}

model DraftFinding {
  id            String    @id @default(cuid())
  engagement_id String
  title         String
  description   String?   @db.Text
  risk_rating   String?   // low | medium | high | critical
  evidence      String?   @db.Text
  status        String    @default("draft") // draft | to_review | reviewed | accepted | rejected
  recommendation String?  @db.Text
  management_response String? @db.Text
  root_cause    String?   @db.Text
  created_by    String?   // placeholder
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  engagement  Engagement              @relation(fields: [engagement_id], references: [id], onDelete: Cascade)
  procedures  DraftFindingProcedure[]
  risk_owners DraftFindingRiskOwner[]
  unit_owners DraftFindingUnitOwner[]

  @@index([engagement_id])
  @@index([status])
  @@map("draft_finding")
}

// Many-to-many: DraftFinding ↔ EngagementProcedure
model DraftFindingProcedure {
  finding_id   String
  procedure_id String

  finding   DraftFinding        @relation(fields: [finding_id], references: [id], onDelete: Cascade)
  procedure EngagementProcedure @relation(fields: [procedure_id], references: [id], onDelete: Cascade)

  @@id([finding_id, procedure_id])
  @@map("draft_finding_procedure")
}

// Many-to-many: DraftFinding ↔ Contact (risk owners)
model DraftFindingRiskOwner {
  finding_id String
  contact_id String

  finding DraftFinding @relation(fields: [finding_id], references: [id], onDelete: Cascade)
  contact Contact      @relation("FindingRiskOwner", fields: [contact_id], references: [id])

  @@id([finding_id, contact_id])
  @@map("draft_finding_risk_owner")
}

// Many-to-many: DraftFinding ↔ OrgUnit (unit owners)
model DraftFindingUnitOwner {
  finding_id String
  unit_id    String

  finding DraftFinding @relation(fields: [finding_id], references: [id], onDelete: Cascade)
  unit    OrgUnit      @relation("FindingUnitOwner", fields: [unit_id], references: [id])

  @@id([finding_id, unit_id])
  @@map("draft_finding_unit_owner")
}

// Many-to-many: EngagementProcedure ↔ EngagementControl (references)
model ProcedureControlRef {
  procedure_id String
  control_id   String

  procedure EngagementProcedure @relation(fields: [procedure_id], references: [id], onDelete: Cascade)
  control   EngagementControl   @relation(fields: [control_id], references: [id], onDelete: Cascade)

  @@id([procedure_id, control_id])
  @@map("procedure_control_ref")
}

// Many-to-many: EngagementProcedure ↔ EngagementRisk (references)
model ProcedureRiskRef {
  procedure_id String
  risk_id      String

  procedure EngagementProcedure @relation(fields: [procedure_id], references: [id], onDelete: Cascade)
  risk      EngagementRisk      @relation(fields: [risk_id], references: [id], onDelete: Cascade)

  @@id([procedure_id, risk_id])
  @@map("procedure_risk_ref")
}

// Many-to-many: EngagementProcedure ↔ EngagementRcmObjective (references)
model ProcedureObjectiveRef {
  procedure_id     String
  rcm_objective_id String

  procedure    EngagementProcedure  @relation(fields: [procedure_id], references: [id], onDelete: Cascade)
  rcmObjective EngagementRcmObjective @relation(fields: [rcm_objective_id], references: [id], onDelete: Cascade)

  @@id([procedure_id, rcm_objective_id])
  @@map("procedure_objective_ref")
}

// =============================================================================
// PLANNING STEP CONFIGURATION — System-level configurable planning steps
// =============================================================================

model PlanningStepConfig {
  id          String   @id @default(cuid())
  key         String   @unique   // "scope" | "objectives" | "understanding" | "rcm" | "work_program" | custom cuid
  title       String              // "Phạm vi & Thông tin chung", "Kế hoạch lấy mẫu", etc.
  icon        String?             // lucide icon name (optional)
  step_type   String              // "fixed" | "workpaper"
  is_active   Boolean  @default(true)
  sort_order  Int      @default(0)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  planning_workpapers PlanningWorkpaper[]

  @@index([sort_order])
  @@map("planning_step_config")
}

// Per-engagement workpaper for generic planning steps (step_type = "workpaper")
model PlanningWorkpaper {
  id               String   @id @default(cuid())
  engagement_id    String
  step_config_id   String
  content          Json?    @db.Json    // Tiptap JSON
  approval_status  String   @default("not_started")  // not_started | in_progress | waiting_review | needs_modification | reviewed | waiting_approval | approved
  current_version  Int      @default(0)
  approved_by      String?
  approved_at      DateTime?
  approved_version Int?
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  engagement  Engagement         @relation(fields: [engagement_id], references: [id], onDelete: Cascade)
  step_config PlanningStepConfig @relation(fields: [step_config_id], references: [id])

  @@unique([engagement_id, step_config_id])
  @@index([engagement_id])
  @@map("planning_workpaper")
}

// =============================================================================
// ENTITY VERSIONING — Publish-only snapshots for any versionable entity
// =============================================================================

model EntityVersion {
  id            String   @id @default(cuid())
  entity_type   String   // "procedure" | "understanding" | future...
  entity_id     String   // FK to the actual record (polymorphic)
  version       Int      // auto-increment per entity (1, 2, 3...)
  version_type  String?  // "transition" | "manual" | "auto" (future-proof)
  action_label  String?  // e.g., "Gửi soát xét", "Phê duyệt" — from transition
  snapshot      Json     @db.Json  // full entity state at publish time
  comment       String?  @db.Text  // optional version comment (= transition comment)
  published_by  String   // user who published
  published_at  DateTime @default(now())

  publisher User @relation("VersionPublisher", fields: [published_by], references: [id])

  @@unique([entity_type, entity_id, version])
  @@index([entity_type, entity_id])
  @@index([published_by])
  @@index([published_at])
  @@map("entity_version")
}

// =============================================================================
// APPROVAL STATUSES — Dynamic status definitions with categories
// =============================================================================

model ApprovalStatus {
  id          String   @id @default(cuid())
  key         String   @unique          // slug: "not_started", "in_progress", etc.
  label       String                    // display: "Chưa bắt đầu"
  color       String   @default("#94a3b8")  // hex from 15-color palette
  category    String                    // "open" | "active" | "review" | "done"
  is_system   Boolean  @default(false)  // true = can't delete or change key/category
  is_archived Boolean  @default(false)  // true = hidden from config but still resolvable for display
  sort_order  Int      @default(0)      // within category for display ordering
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([category])
  @@map("approval_status")
}

// =============================================================================
// APPROVAL WORKFLOWS — Configurable state-machine per entity type
// =============================================================================

model ApprovalWorkflow {
  id                  String   @id @default(cuid())
  entity_type         String?  @unique  // DEPRECATED — use ApprovalEntityBinding instead
  name                String             // display name, e.g. "Quy trình 2 bước"
  allow_self_approval Boolean  @default(false)  // CAE always allowed regardless
  is_active           Boolean  @default(true)
  is_default          Boolean  @default(false)   // fallback when entity type has no binding
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  transitions     ApprovalTransition[]
  entity_bindings ApprovalEntityBinding[]

  @@map("approval_workflow")
}

// Maps entity types to workflows (many entity types → one workflow)
model ApprovalEntityBinding {
  id           String @id @default(cuid())
  entity_type  String @unique   // "procedure" | "work_program" | "planning_workpaper" | etc.
  workflow_id  String
  label        String?          // display name for the entity type, e.g. "Thủ tục kiểm toán"

  workflow ApprovalWorkflow @relation(fields: [workflow_id], references: [id], onDelete: Cascade)

  @@index([workflow_id])
  @@map("approval_entity_binding")
}

model ApprovalTransition {
  id            String  @id @default(cuid())
  workflow_id   String
  from_status   String  // "draft" | "waiting_review" | "needs_modification" | "reviewed"
  to_status     String  // target status
  action_label  String  // UI button label: "Gửi soát xét" | "Phê duyệt" | "Yêu cầu chỉnh sửa"
  action_type   String  // semantic: "submit" | "approve" | "reject" | "revise"
  allowed_roles Json    // ["reviewer","lead","cae"] — engagement member roles + system roles
  sort_order    Int     @default(0)
  generates_signoff Boolean @default(false) // true → creates a signoff slot
  signoff_type      String? // 'prepare' | 'review' | 'approve' — required when generates_signoff = true

  workflow ApprovalWorkflow @relation(fields: [workflow_id], references: [id], onDelete: Cascade)

  @@unique([workflow_id, from_status, to_status])
  @@index([workflow_id])
  @@map("approval_transition")
}

// =============================================================================
// WORKPAPER COMMENTS — Inline comment threads on documents
// =============================================================================

model WpCommentThread {
  id             String    @id @default(cuid())
  entity_type    String    // procedure | risk_assessment | understanding
  entity_id      String    // FK to the entity (polymorphic)
  thread_type    String    @default("comment") // comment | review_note
  quote          String?   @db.Text   // original selected text
  content_anchor String?   @db.Text   // serialized position info for anchoring
  status         String    @default("open") // open | resolved | detached
  created_by     String
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  creator  User          @relation("WpThreadCreator", fields: [created_by], references: [id])
  comments WpComment[]

  @@index([entity_type, entity_id])
  @@index([status])
  @@index([created_by])
  @@map("wp_comment_thread")
}

model WpComment {
  id         String    @id @default(cuid())
  thread_id  String
  content    String    @db.Text
  author_id  String
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt

  thread WpCommentThread @relation(fields: [thread_id], references: [id], onDelete: Cascade)
  author User            @relation("WpCommentAuthor", fields: [author_id], references: [id])

  @@index([thread_id])
  @@index([author_id])
  @@map("wp_comment")
}

// =============================================================================
// TEMPLATE LIBRARY — Reusable rich-text templates for workpapers
// =============================================================================

model TemplateCategory {
  id        String   @id @default(cuid())
  name      String
  parent_id String?
  sort_order Int     @default(0)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  parent   TemplateCategory?  @relation("CategoryTree", fields: [parent_id], references: [id], onDelete: SetNull)
  children TemplateCategory[] @relation("CategoryTree")
  templates Template[]

  @@index([parent_id])
  @@map("template_category")
}

model Template {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  content     Json     // Tiptap JSON content
  entity_type String   // "procedure" | "planning_workpaper" | "entity_risk_assessment"
  category_id String?
  is_active   Boolean  @default(true)
  created_by  String
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  category TemplateCategory? @relation(fields: [category_id], references: [id], onDelete: SetNull)
  creator  User              @relation("TemplateCreator", fields: [created_by], references: [id])
  bindings TemplateEntityBinding[]

  @@index([entity_type])
  @@index([category_id])
  @@index([created_by])
  @@map("template")
}

// =============================================================================
// TEMPLATE ENTITY BINDING — Maps entity types to default templates
// =============================================================================

model TemplateEntityBinding {
  id          String @id @default(cuid())
  entity_type String   // "procedure" | "planning_workpaper" | "entity_risk_assessment"
  sub_type    String @default("")  // "" for base types, step config key for planning_workpaper, etc.
  template_id String

  template Template @relation(fields: [template_id], references: [id], onDelete: Cascade)

  @@unique([entity_type, sub_type])
  @@index([template_id])
  @@map("template_entity_binding")
}
